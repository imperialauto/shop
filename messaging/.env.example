# Quo (formerly OpenPhone) — generate an API key under Workspace Settings > API.
QUO_API_KEY=
QUO_DEFAULT_FROM_NUMBER=+1XXXXXXXXXX
QUO_DEFAULT_USER_ID=
# The Quo phone number ID (starts PN...) — used by the backfill script and
# quoClient.listMessages. Find it via GET /v1/phone-numbers, or leave unset
# and the backfill script will look it up and print it for you.
QUO_PHONE_NUMBER_ID=
QUO_WEBHOOK_SIGNING_SECRET=
# Only needed if/when your webhook subscription is on the newer Standard
# Webhooks-compatible scheme (whsec_... secret). See
# src/lib/verifyQuoWebhookSignature.js for the difference.
QUO_WEBHOOK_SIGNING_SECRET_STANDARD=
# Force a scheme instead of auto-detecting: "legacy" or "standard". Leave
# unset to auto-detect from whichever header the request arrives with.
QUO_WEBHOOK_SCHEME=

# Groq (AI draft replies) — OpenAI-compatible chat completions API.
GROQ_API_KEY=
# Optional — defaults to llama-3.3-70b-versatile if unset.
GROQ_DRAFT_MODEL=

# Shop app internal API (imperialauto/shop "web" Railway service) — used
# for real repair-order/customer context in AI drafts and for generating
# e-signature links (see src/lib/shopClient.js). Optional: if unset, this
# feature just degrades to drafting without job context, same as before.
# INTERNAL_API_KEY must match the value set on the "web" service.
SHOP_APP_API_URL=
INTERNAL_API_KEY=

# Database — this service's OWN Postgres (separate from the shop app's DB;
# see prisma/schema.prisma for why). Railway's Postgres plugin sets this
# automatically if attached to this service.
DATABASE_URL=

# Dashboard access — this service is public on the internet with real
# customer conversations in it, so it's gated behind HTTP Basic Auth. Pick
# your own values; there's no default. See src/lib/basicAuth.js.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

# App
PORT=3000
NODE_ENV=development
