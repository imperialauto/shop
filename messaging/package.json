{
  "name": "iac-messaging-module",
  "version": "1.0.0",
  "private": true,
  "description": "Quo texting + AI draft-reply module for the Imperial Auto Care Cowork dashboard",
  "main": "server.js",
  "scripts": {
    "start": "prisma db push --skip-generate && node server.js",
    "postinstall": "prisma generate",
    "backfill": "node src/scripts/backfillQuoHistory.js",
    "migrate": "prisma migrate dev --name init"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^5.20.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "prisma": "^5.20.0"
  }
}
