# Copy this to .env and fill in your values
SECRET_KEY=change-this-to-a-random-secret-key
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENPHONE_API_KEY=your-openphone-api-key-here
OPENPHONE_SIGNING_SECRET=your-openphone-signing-secret-here

# Database — leave blank to use SQLite locally
# On Railway this is set automatically when you add the PostgreSQL addon
DATABASE_URL=
